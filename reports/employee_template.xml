<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="employee_report_template">
        <t t-call="web.external_layout">
            <div class="page">

                <h2>Employee Report</h2>

                <p><strong>Employee ID:</strong> <t t-esc="doc.employee_id"/></p>
                <p><strong>Name:</strong> <t t-esc="doc.name"/></p>
                <p><strong>Department:</strong> <t t-esc="doc.department_id.name"/></p>
                <p><strong>Job Position:</strong> <t t-esc="doc.job_position.name"/></p>
                <p><strong>Email:</strong> <t t-esc="doc.work_email"/></p>
                <p><strong>Phone:</strong> <t t-esc="doc.work_phone"/></p>

            </div>
        </t>
    </template>
</odoo>