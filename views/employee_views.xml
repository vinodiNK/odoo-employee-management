<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- TREE VIEW -->
        <record id="view_employee_data_management_tree" model="ir.ui.view">
            <field name="name">employee.data.management.tree</field>
            <field name="model">employee.data.management</field>
            <field name="arch" type="xml">
                <tree string="Employees">
                    <field name="employee_id"/>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="job_position"/>
                    <field name="work_email"/>
                    <field name="work_phone"/>
                </tree>
            </field>
        </record>

        <!-- KANBAN VIEW -->
        <record id="view_employee_data_management_kanban" model="ir.ui.view">
            <field name="name">employee.data.management.kanban</field>
            <field name="model">employee.data.management</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="employee_id"/>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="job_position"/>

                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_card">

                                <div style="font-weight:bold;">
                                    <field name="employee_id"/>
                                </div>

                                <div style="font-size:16px;">
                                    <field name="name"/>
                                </div>

                                <div style="color:gray;">
                                    Job: <field name="job_position"/>
                                </div>

                                <div>
                                    <i class="fa fa-envelope"/> <field name="work_email"/>
                                </div>

                                <div>
                                    <i class="fa fa-phone"/> <field name="work_phone"/>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_employee_data_management_form" model="ir.ui.view">
            <field name="name">employee.data.management.form</field>
            <field name="model">employee.data.management</field>
            <field name="arch" type="xml">
                <form string="Employee">

                    <header>
    <field name="state" widget="statusbar" statusbar_visible="draft,saved"/>

    <!-- Save Button -->
    <button name="action_save"
            type="object"
            string="Save"
            class="btn-primary"
            invisible="state == 'saved'"/>

    <!-- Print PDF -->
    <button name="action_print_pdf"
            type="object"
            string="Print PDF Report"
            class="btn-secondary"
            invisible="state == 'draft'"/>

    <!-- Print Excel -->
    <button name="action_print_excel"
            type="object"
            string="Print Excel Report"
            class="btn-success"
            invisible="state == 'draft'"/>
</header>

                    <sheet>

                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="name" readonly="state == 'saved'"/>
                            <field name="department_id" readonly="state == 'saved'"/>
                            <field name="job_position" readonly="state == 'saved'"/>
                            <field name="work_address" readonly="state == 'saved'"/>
                            <field name="work_email" readonly="state == 'saved'"/>
                            <field name="work_phone" readonly="state == 'saved'"/>
                        </group>


                        <notebook>
                            <page string="Private Info">
                                <group>
                                    <field name="private_address" readonly="state == 'saved'"/>
                                    <field name="private_email" readonly="state == 'saved'"/>
                                    <field name="private_phone" readonly="state == 'saved'"/>
                                </group>
                            </page>
                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_employee_data_management" model="ir.actions.act_window">
            <field name="name">Employees</field>
            <field name="res_model">employee.data.management</field>
            <field name="view_mode">kanban,tree,form</field>
        </record>

    </data>
</odoo>